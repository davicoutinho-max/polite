      <bpmn:sequenceFlow id="Process_citizen_participation_flow_10" sourceRef="Process_citizen_participation_g2" targetRef="Process_citizen_participation_c4" name="No" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_11" sourceRef="Process_citizen_participation_c3" targetRef="Process_citizen_participation_end2" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_12" sourceRef="Process_citizen_participation_c4" targetRef="Process_citizen_participation_end2" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_13" sourceRef="Process_citizen_participation_g0" targetRef="Process_citizen_participation_s1" name="Surveys" />
