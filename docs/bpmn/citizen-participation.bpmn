                   name="Citizen Participation (Petitions, Consultations, Surveys)">
  <bpmn:collaboration id="Collaboration_citizen_participation">
    <bpmn:participant id="Process_citizen_participation_participant" name="Citizen Participation (Petitions, Consultations, Surveys)" processRef="Process_citizen_participation" />
  </bpmn:collaboration>
  <bpmn:process id="Process_citizen_participation" name="Citizen Participation (Petitions, Consultations, Surveys)" isExecutable="false">
    <bpmn:laneSet id="Process_citizen_participation_laneSet">
      <bpmn:lane id="Process_citizen_participation_lane_0" name="Citizen — Petitions">
        <bpmn:flowNodeRef>Process_citizen_participation_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_g0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_p1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_end1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_end1b</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_citizen_participation_lane_1" name="Participation Service (Petitions)">
        <bpmn:flowNodeRef>Process_citizen_participation_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_p2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_citizen_participation_lane_2" name="Citizen — Consultations">
        <bpmn:flowNodeRef>Process_citizen_participation_c1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_c2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_end2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_citizen_participation_lane_3" name="Participation Service (Consultations)">
        <bpmn:flowNodeRef>Process_citizen_participation_g2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_c3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_c4</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_citizen_participation_lane_4" name="Citizen — Surveys">
        <bpmn:flowNodeRef>Process_citizen_participation_s1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_end3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_end3b</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_citizen_participation_lane_5" name="Participation Service (Surveys)">
        <bpmn:flowNodeRef>Process_citizen_participation_g3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_citizen_participation_s2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_citizen_participation_start" name="Open Participation (requires participate)" />
      <bpmn:exclusiveGateway id="Process_citizen_participation_g0" name="Choose tab" />
      <bpmn:task id="Process_citizen_participation_p1" name="View petition" />
      <bpmn:exclusiveGateway id="Process_citizen_participation_g1" name="Already signed?" />
      <bpmn:task id="Process_citizen_participation_p2" name="Sign: signatures++, signed=true" />
      <bpmn:endEvent id="Process_citizen_participation_end1" name="Signature recorded" />
      <bpmn:endEvent id="Process_citizen_participation_end1b" name="Already signed (no-op)" />
      <bpmn:task id="Process_citizen_participation_c1" name="Read consultation description" />
      <bpmn:task id="Process_citizen_participation_c2" name="Choose stance (favor / against / neutral)" />
      <bpmn:exclusiveGateway id="Process_citizen_participation_g2" name="First response from this citizen?" />
      <bpmn:task id="Process_citizen_participation_c3" name="responses++, store stance" />
      <bpmn:task id="Process_citizen_participation_c4" name="Overwrite stance (no recount)" />
      <bpmn:endEvent id="Process_citizen_participation_end2" name="Stance recorded" />
      <bpmn:task id="Process_citizen_participation_s1" name="View survey options" />
      <bpmn:exclusiveGateway id="Process_citizen_participation_g3" name="Already voted?" />
      <bpmn:task id="Process_citizen_participation_s2" name="Vote option, lock votedOptionId" />
      <bpmn:endEvent id="Process_citizen_participation_end3" name="Vote recorded" />
      <bpmn:endEvent id="Process_citizen_participation_end3b" name="Read-only (already voted)" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_0" sourceRef="Process_citizen_participation_start" targetRef="Process_citizen_participation_g0" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_1" sourceRef="Process_citizen_participation_g0" targetRef="Process_citizen_participation_p1" name="Petitions" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_2" sourceRef="Process_citizen_participation_p1" targetRef="Process_citizen_participation_g1" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_3" sourceRef="Process_citizen_participation_g1" targetRef="Process_citizen_participation_p2" name="No" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_4" sourceRef="Process_citizen_participation_p2" targetRef="Process_citizen_participation_end1" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_5" sourceRef="Process_citizen_participation_g1" targetRef="Process_citizen_participation_end1b" name="Yes" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_6" sourceRef="Process_citizen_participation_g0" targetRef="Process_citizen_participation_c1" name="Consultations" />
      <bpmn:sequenceFlow id="Process_citizen_participation_flow_7" sourceRef="Process_citizen_participation_c1" targetRef="Process_citizen_participation_c2" />
