<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   id="Definitions_elections_browsing"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Elections Browsing &amp; Candidacy Lookup">
  <bpmn:collaboration id="Collaboration_elections_browsing">
    <bpmn:participant id="Process_elections_browsing_participant" name="Elections Browsing &amp; Candidacy Lookup" processRef="Process_elections_browsing" />
  </bpmn:collaboration>
  <bpmn:process id="Process_elections_browsing" name="Elections Browsing &amp; Candidacy Lookup" isExecutable="false">
    <bpmn:laneSet id="Process_elections_browsing_laneSet">
      <bpmn:lane id="Process_elections_browsing_lane_0" name="Any User (incl. Visitor)">
        <bpmn:flowNodeRef>Process_elections_browsing_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_elections_browsing_t2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_elections_browsing_t3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_elections_browsing_t7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_elections_browsing_t8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_elections_browsing_end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_elections_browsing_lane_1" name="Elections Service">
        <bpmn:flowNodeRef>Process_elections_browsing_t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_elections_browsing_t4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_elections_browsing_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_elections_browsing_t6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_elections_browsing_end0</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_elections_browsing_lane_2" name="Directory Service">
        <bpmn:flowNodeRef>Process_elections_browsing_t5</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_elections_browsing_start" name="Open /elections (public, no auth)" />
      <bpmn:task id="Process_elections_browsing_t1" name="Return elections list + stats (upcoming, candidates, next date)" />
      <bpmn:task id="Process_elections_browsing_t2" name="Filter by scope (Nacional/Estadual/Municipal/All)" />
      <bpmn:task id="Process_elections_browsing_t3" name="Click an election card" />
      <bpmn:task id="Process_elections_browsing_t4" name="byId lookup + candidatesOf(electionId)" />
      <bpmn:task id="Process_elections_browsing_t5" name="Join candidate ids with PoliticianSummary records" />
      <bpmn:exclusiveGateway id="Process_elections_browsing_g1" name="Election found?" />
      <bpmn:task id="Process_elections_browsing_t6" name="Show &quot;not found&quot; empty state" />
      <bpmn:endEvent id="Process_elections_browsing_end0" name="Empty state shown" />
      <bpmn:task id="Process_elections_browsing_t7" name="Render detail: status computed from date vs now" />
      <bpmn:task id="Process_elections_browsing_t8" name="Click a candidate → open their Profile" />
      <bpmn:endEvent id="Process_elections_browsing_end" name="Candidate profile opened" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_0" sourceRef="Process_elections_browsing_start" targetRef="Process_elections_browsing_t1" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_1" sourceRef="Process_elections_browsing_t1" targetRef="Process_elections_browsing_t2" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_2" sourceRef="Process_elections_browsing_t2" targetRef="Process_elections_browsing_t3" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_3" sourceRef="Process_elections_browsing_t3" targetRef="Process_elections_browsing_t4" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_4" sourceRef="Process_elections_browsing_t4" targetRef="Process_elections_browsing_t5" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_5" sourceRef="Process_elections_browsing_t5" targetRef="Process_elections_browsing_g1" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_6" sourceRef="Process_elections_browsing_g1" targetRef="Process_elections_browsing_t6" name="No" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_7" sourceRef="Process_elections_browsing_t6" targetRef="Process_elections_browsing_end0" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_8" sourceRef="Process_elections_browsing_g1" targetRef="Process_elections_browsing_t7" name="Yes" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_9" sourceRef="Process_elections_browsing_t7" targetRef="Process_elections_browsing_t8" />
      <bpmn:sequenceFlow id="Process_elections_browsing_flow_10" sourceRef="Process_elections_browsing_t8" targetRef="Process_elections_browsing_end" />
  </bpmn:process>
