                   id="Definitions_privacy_lgpd"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Privacy, Consent &amp; LGPD Data Rights">
  <bpmn:collaboration id="Collaboration_privacy_lgpd">
    <bpmn:participant id="Process_privacy_lgpd_participant" name="Privacy, Consent &amp; LGPD Data Rights" processRef="Process_privacy_lgpd" />
  </bpmn:collaboration>
  <bpmn:process id="Process_privacy_lgpd" name="Privacy, Consent &amp; LGPD Data Rights" isExecutable="false">
    <bpmn:laneSet id="Process_privacy_lgpd_laneSet">
      <bpmn:lane id="Process_privacy_lgpd_lane_0" name="User">
        <bpmn:flowNodeRef>Process_privacy_lgpd_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_g0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_exp1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_end1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_privacy_lgpd_lane_1" name="Privacy/Compliance Service">
        <bpmn:flowNodeRef>Process_privacy_lgpd_t2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_exp2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_exp4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_del4</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_privacy_lgpd_lane_2" name="All Domain Services (data owners)">
        <bpmn:flowNodeRef>Process_privacy_lgpd_exp3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_del3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_privacy_lgpd_lane_3" name="User (Delete flow)">
        <bpmn:flowNodeRef>Process_privacy_lgpd_del1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_del2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_end2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_privacy_lgpd_end3</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_privacy_lgpd_start" name="Open Privacy &amp; Data" />
      <bpmn:task id="Process_privacy_lgpd_t1" name="View/toggle consent (essential locked, rest togglable)" />
      <bpmn:task id="Process_privacy_lgpd_t2" name="Persist consent preferences" />
      <bpmn:exclusiveGateway id="Process_privacy_lgpd_g0" name="Action?" />
      <bpmn:task id="Process_privacy_lgpd_exp1" name="Click &quot;Export my data&quot;" />
      <bpmn:task id="Process_privacy_lgpd_exp2" name="Aggregate personal data across services" />
      <bpmn:task id="Process_privacy_lgpd_exp3" name="Return profile, posts, messages, wallet, participation" />
      <bpmn:task id="Process_privacy_lgpd_exp4" name="Generate JSON snapshot" />
      <bpmn:endEvent id="Process_privacy_lgpd_end1" name="Download delivered (right to portability)" />
      <bpmn:task id="Process_privacy_lgpd_del1" name="Click &quot;Delete my account&quot;" />
      <bpmn:task id="Process_privacy_lgpd_del2" name="Confirm irreversible warning" />
      <bpmn:exclusiveGateway id="Process_privacy_lgpd_g1" name="Confirmed?" />
      <bpmn:task id="Process_privacy_lgpd_del3" name="Erase personal data (right to erasure), anonymize authored content" />
      <bpmn:task id="Process_privacy_lgpd_del4" name="Terminate session, sign out" />
      <bpmn:endEvent id="Process_privacy_lgpd_end2" name="Account deleted" />
      <bpmn:endEvent id="Process_privacy_lgpd_end3" name="Cancelled" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_0" sourceRef="Process_privacy_lgpd_start" targetRef="Process_privacy_lgpd_t1" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_1" sourceRef="Process_privacy_lgpd_t1" targetRef="Process_privacy_lgpd_t2" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_2" sourceRef="Process_privacy_lgpd_t2" targetRef="Process_privacy_lgpd_g0" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_3" sourceRef="Process_privacy_lgpd_g0" targetRef="Process_privacy_lgpd_exp1" name="Export" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_4" sourceRef="Process_privacy_lgpd_exp1" targetRef="Process_privacy_lgpd_exp2" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_5" sourceRef="Process_privacy_lgpd_exp2" targetRef="Process_privacy_lgpd_exp3" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_6" sourceRef="Process_privacy_lgpd_exp3" targetRef="Process_privacy_lgpd_exp4" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_7" sourceRef="Process_privacy_lgpd_exp4" targetRef="Process_privacy_lgpd_end1" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_8" sourceRef="Process_privacy_lgpd_g0" targetRef="Process_privacy_lgpd_del1" name="Delete" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_9" sourceRef="Process_privacy_lgpd_del1" targetRef="Process_privacy_lgpd_del2" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_10" sourceRef="Process_privacy_lgpd_del2" targetRef="Process_privacy_lgpd_g1" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_11" sourceRef="Process_privacy_lgpd_g1" targetRef="Process_privacy_lgpd_del3" name="Yes" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_12" sourceRef="Process_privacy_lgpd_del3" targetRef="Process_privacy_lgpd_del4" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_13" sourceRef="Process_privacy_lgpd_del4" targetRef="Process_privacy_lgpd_end2" />
      <bpmn:sequenceFlow id="Process_privacy_lgpd_flow_14" sourceRef="Process_privacy_lgpd_g1" targetRef="Process_privacy_lgpd_end3" name="No" />
  </bpmn:process>
