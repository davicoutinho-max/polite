<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   id="Definitions_party_onboarding_platform_admin"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Party Onboarding &amp; Politician Assignment (Platform Admin)">
  <bpmn:collaboration id="Collaboration_party_onboarding_platform_admin">
    <bpmn:participant id="Process_party_onboarding_platform_admin_participant" name="Party Onboarding &amp; Politician Assignment (Platform Admin)" processRef="Process_party_onboarding_platform_admin" />
  </bpmn:collaboration>
  <bpmn:process id="Process_party_onboarding_platform_admin" name="Party Onboarding &amp; Politician Assignment (Platform Admin)" isExecutable="false">
    <bpmn:laneSet id="Process_party_onboarding_platform_admin_laneSet">
      <bpmn:lane id="Process_party_onboarding_platform_admin_lane_0" name="Platform Admin — New Party">
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_end1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_party_onboarding_platform_admin_lane_1" name="Party Registry">
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_t2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_t3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_t4</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_party_onboarding_platform_admin_lane_2" name="Platform Admin — Reassignment">
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_start2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_t5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_end2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_party_onboarding_platform_admin_lane_3" name="Politician Directory">
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_g2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_t6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_party_onboarding_platform_admin_t7</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_party_onboarding_platform_admin_start" name="Open Platform Admin → Register a party" />
      <bpmn:task id="Process_party_onboarding_platform_admin_t1" name="Fill Name, Acronym, Number, President, Ideology" />
      <bpmn:exclusiveGateway id="Process_party_onboarding_platform_admin_g1" name="Acronym/id already taken?" />
      <bpmn:task id="Process_party_onboarding_platform_admin_t2" name="Suffix id with timestamp" />
      <bpmn:task id="Process_party_onboarding_platform_admin_t3" name="Create PartyRegistryEntry (memberCount=0)" />
      <bpmn:task id="Process_party_onboarding_platform_admin_t4" name="Party visible in registered- parties list &amp; public directory" />
      <bpmn:endEvent id="Process_party_onboarding_platform_admin_end1" name="Party registered" />
      <bpmn:startEvent id="Process_party_onboarding_platform_admin_start2" name="Select an independent or affiliated politician" />
      <bpmn:task id="Process_party_onboarding_platform_admin_t5" name="Choose target party (or &quot;Independent&quot;)" />
      <bpmn:exclusiveGateway id="Process_party_onboarding_platform_admin_g2" name="Already assigned elsewhere?" />
      <bpmn:task id="Process_party_onboarding_platform_admin_t6" name="Move from previous party to new one" />
      <bpmn:task id="Process_party_onboarding_platform_admin_t7" name="Set partyId (or null)" />
      <bpmn:endEvent id="Process_party_onboarding_platform_admin_end2" name="Assignment updated" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_0" sourceRef="Process_party_onboarding_platform_admin_start" targetRef="Process_party_onboarding_platform_admin_t1" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_1" sourceRef="Process_party_onboarding_platform_admin_t1" targetRef="Process_party_onboarding_platform_admin_g1" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_2" sourceRef="Process_party_onboarding_platform_admin_g1" targetRef="Process_party_onboarding_platform_admin_t2" name="Yes" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_3" sourceRef="Process_party_onboarding_platform_admin_t2" targetRef="Process_party_onboarding_platform_admin_t3" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_4" sourceRef="Process_party_onboarding_platform_admin_g1" targetRef="Process_party_onboarding_platform_admin_t3" name="No" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_5" sourceRef="Process_party_onboarding_platform_admin_t3" targetRef="Process_party_onboarding_platform_admin_t4" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_6" sourceRef="Process_party_onboarding_platform_admin_t4" targetRef="Process_party_onboarding_platform_admin_end1" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_7" sourceRef="Process_party_onboarding_platform_admin_start2" targetRef="Process_party_onboarding_platform_admin_t5" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_8" sourceRef="Process_party_onboarding_platform_admin_t5" targetRef="Process_party_onboarding_platform_admin_g2" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_9" sourceRef="Process_party_onboarding_platform_admin_g2" targetRef="Process_party_onboarding_platform_admin_t6" name="Yes" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_10" sourceRef="Process_party_onboarding_platform_admin_t6" targetRef="Process_party_onboarding_platform_admin_end2" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_11" sourceRef="Process_party_onboarding_platform_admin_g2" targetRef="Process_party_onboarding_platform_admin_t7" name="No" />
      <bpmn:sequenceFlow id="Process_party_onboarding_platform_admin_flow_12" sourceRef="Process_party_onboarding_platform_admin_t7" targetRef="Process_party_onboarding_platform_admin_end2" />
  </bpmn:process>
