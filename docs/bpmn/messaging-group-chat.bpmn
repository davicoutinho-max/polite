      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Process_messaging_group_chat_flow_6_di" bpmnElement="Process_messaging_group_chat_flow_6">
        <di:waypoint x="1151" y="265" />
        <di:waypoint x="1321" y="265" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Process_messaging_group_chat_flow_7_di" bpmnElement="Process_messaging_group_chat_flow_7">
        <di:waypoint x="1321" y="265" />
        <di:waypoint x="1491" y="115" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Process_messaging_group_chat_flow_8_di" bpmnElement="Process_messaging_group_chat_flow_8">
        <di:waypoint x="1491" y="115" />
        <di:waypoint x="1661" y="265" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Process_messaging_group_chat_flow_9_di" bpmnElement="Process_messaging_group_chat_flow_9">
        <di:waypoint x="1661" y="265" />
        <di:waypoint x="1831" y="565" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Process_messaging_group_chat_flow_10_di" bpmnElement="Process_messaging_group_chat_flow_10">
        <di:waypoint x="1831" y="565" />
        <di:waypoint x="2001" y="265" />
      </bpmndi:BPMNEdge>
    </bpmndi:BPMNPlane>
  </bpmndi:BPMNDiagram>
</bpmn:definitions>
