<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   id="Definitions_membership_fee_billing"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Membership Fee Billing &amp; Payment">
  <bpmn:collaboration id="Collaboration_membership_fee_billing">
    <bpmn:participant id="Process_membership_fee_billing_participant" name="Membership Fee Billing &amp; Payment" processRef="Process_membership_fee_billing" />
  </bpmn:collaboration>
  <bpmn:process id="Process_membership_fee_billing" name="Membership Fee Billing &amp; Payment" isExecutable="false">
    <bpmn:laneSet id="Process_membership_fee_billing_laneSet">
      <bpmn:lane id="Process_membership_fee_billing_lane_0" name="Billing Service (scheduler)">
        <bpmn:flowNodeRef>Process_membership_fee_billing_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_membership_fee_billing_t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_membership_fee_billing_t2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_membership_fee_billing_t5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_membership_fee_billing_t6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_membership_fee_billing_end1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_membership_fee_billing_lane_1" name="Citizen">
        <bpmn:flowNodeRef>Process_membership_fee_billing_t3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_membership_fee_billing_end2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_membership_fee_billing_lane_2" name="Payment Gateway (external)">
        <bpmn:flowNodeRef>Process_membership_fee_billing_t4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_membership_fee_billing_g1</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_membership_fee_billing_start" name="Monthly billing cycle (per affiliation anniversary)"><bpmn:timerEventDefinition /></bpmn:startEvent>
      <bpmn:task id="Process_membership_fee_billing_t1" name="Generate MembershipFee (reference, amount, dueDate, status=pending)" />
      <bpmn:task id="Process_membership_fee_billing_t2" name="Notify citizen (alert + email)" />
      <bpmn:task id="Process_membership_fee_billing_t3" name="Open Wallet → Pay contribution" />
      <bpmn:task id="Process_membership_fee_billing_t4" name="Process payment (Pix / card / boleto)" />
      <bpmn:exclusiveGateway id="Process_membership_fee_billing_g1" name="Authorized?" />
      <bpmn:task id="Process_membership_fee_billing_t5" name="Keep pending; escalate to overdue after due date" />
      <bpmn:task id="Process_membership_fee_billing_t6" name="status = paid, paidAt = now" />
      <bpmn:endEvent id="Process_membership_fee_billing_end1" name="Overdue (retry later)" />
      <bpmn:endEvent id="Process_membership_fee_billing_end2" name="Contribution recorded" />
      <bpmn:sequenceFlow id="Process_membership_fee_billing_flow_0" sourceRef="Process_membership_fee_billing_start" targetRef="Process_membership_fee_billing_t1" />
      <bpmn:sequenceFlow id="Process_membership_fee_billing_flow_1" sourceRef="Process_membership_fee_billing_t1" targetRef="Process_membership_fee_billing_t2" />
      <bpmn:sequenceFlow id="Process_membership_fee_billing_flow_2" sourceRef="Process_membership_fee_billing_t2" targetRef="Process_membership_fee_billing_t3" />
      <bpmn:sequenceFlow id="Process_membership_fee_billing_flow_3" sourceRef="Process_membership_fee_billing_t3" targetRef="Process_membership_fee_billing_t4" />
      <bpmn:sequenceFlow id="Process_membership_fee_billing_flow_4" sourceRef="Process_membership_fee_billing_t4" targetRef="Process_membership_fee_billing_g1" />
      <bpmn:sequenceFlow id="Process_membership_fee_billing_flow_5" sourceRef="Process_membership_fee_billing_g1" targetRef="Process_membership_fee_billing_t5" name="No" />
      <bpmn:sequenceFlow id="Process_membership_fee_billing_flow_6" sourceRef="Process_membership_fee_billing_t5" targetRef="Process_membership_fee_billing_end1" />
      <bpmn:sequenceFlow id="Process_membership_fee_billing_flow_7" sourceRef="Process_membership_fee_billing_g1" targetRef="Process_membership_fee_billing_t6" name="Yes" />
      <bpmn:sequenceFlow id="Process_membership_fee_billing_flow_8" sourceRef="Process_membership_fee_billing_t6" targetRef="Process_membership_fee_billing_end2" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_membership_fee_billing">
    <bpmndi:BPMNPlane id="Plane_membership_fee_billing" bpmnElement="Collaboration_membership_fee_billing">
