<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   id="Definitions_fundraising_campaign"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Fundraising Campaign Lifecycle">
  <bpmn:collaboration id="Collaboration_fundraising_campaign">
    <bpmn:participant id="Process_fundraising_campaign_participant" name="Fundraising Campaign Lifecycle" processRef="Process_fundraising_campaign" />
  </bpmn:collaboration>
  <bpmn:process id="Process_fundraising_campaign" name="Fundraising Campaign Lifecycle" isExecutable="false">
    <bpmn:laneSet id="Process_fundraising_campaign_laneSet">
      <bpmn:lane id="Process_fundraising_campaign_lane_0" name="Organizer (Politician/Party)">
        <bpmn:flowNodeRef>Process_fundraising_campaign_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_e1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_fundraising_campaign_lane_1" name="Fundraising Service">
        <bpmn:flowNodeRef>Process_fundraising_campaign_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_t2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_t3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_t5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_t6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_g3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_t7</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_fundraising_campaign_lane_2" name="Supporter (Citizen)">
        <bpmn:flowNodeRef>Process_fundraising_campaign_t4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_g2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_fundraising_campaign_e2</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_fundraising_campaign_start" name="Create action (requires create-fundraiser)" />
      <bpmn:task id="Process_fundraising_campaign_t1" name="Fill Title, Description, Category, Goal, Deadline" />
      <bpmn:exclusiveGateway id="Process_fundraising_campaign_g1" name="Fields valid?" />
      <bpmn:task id="Process_fundraising_campaign_e1" name="Block create" />
      <bpmn:task id="Process_fundraising_campaign_t2" name="Create Fundraiser (raised=0, ledgerPublic=true)" />
      <bpmn:task id="Process_fundraising_campaign_t3" name="Publish to public Fundraising directory" />
      <bpmn:task id="Process_fundraising_campaign_t4" name="Browse &amp; pick amount ($25 / $50 / $100 / custom)" />
      <bpmn:exclusiveGateway id="Process_fundraising_campaign_g2" name="Signed in?" />
      <bpmn:task id="Process_fundraising_campaign_e2" name="Prompt sign in" />
      <bpmn:task id="Process_fundraising_campaign_t5" name="Process contribution (payment gateway)" />
      <bpmn:task id="Process_fundraising_campaign_t6" name="Increment raised/supporters, append public ledger entry" />
      <bpmn:exclusiveGateway id="Process_fundraising_campaign_g3" name="Goal reached?" />
      <bpmn:task id="Process_fundraising_campaign_t7" name="Mark fully funded" />
      <bpmn:endEvent id="Process_fundraising_campaign_end" name="Contribution recorded" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_0" sourceRef="Process_fundraising_campaign_start" targetRef="Process_fundraising_campaign_t1" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_1" sourceRef="Process_fundraising_campaign_t1" targetRef="Process_fundraising_campaign_g1" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_2" sourceRef="Process_fundraising_campaign_g1" targetRef="Process_fundraising_campaign_e1" name="No" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_3" sourceRef="Process_fundraising_campaign_e1" targetRef="Process_fundraising_campaign_t1" name="retry" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_4" sourceRef="Process_fundraising_campaign_g1" targetRef="Process_fundraising_campaign_t2" name="Yes" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_5" sourceRef="Process_fundraising_campaign_t2" targetRef="Process_fundraising_campaign_t3" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_6" sourceRef="Process_fundraising_campaign_t3" targetRef="Process_fundraising_campaign_t4" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_7" sourceRef="Process_fundraising_campaign_t4" targetRef="Process_fundraising_campaign_g2" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_8" sourceRef="Process_fundraising_campaign_g2" targetRef="Process_fundraising_campaign_e2" name="No" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_9" sourceRef="Process_fundraising_campaign_g2" targetRef="Process_fundraising_campaign_t5" name="Yes" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_10" sourceRef="Process_fundraising_campaign_t5" targetRef="Process_fundraising_campaign_t6" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_11" sourceRef="Process_fundraising_campaign_t6" targetRef="Process_fundraising_campaign_g3" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_12" sourceRef="Process_fundraising_campaign_g3" targetRef="Process_fundraising_campaign_t7" name="Yes" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_13" sourceRef="Process_fundraising_campaign_t7" targetRef="Process_fundraising_campaign_end" />
      <bpmn:sequenceFlow id="Process_fundraising_campaign_flow_14" sourceRef="Process_fundraising_campaign_g3" targetRef="Process_fundraising_campaign_end" name="No" />
  </bpmn:process>
