<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   id="Definitions_auth_registration_login"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Account Registration &amp; Login">
  <bpmn:collaboration id="Collaboration_auth_registration_login">
    <bpmn:participant id="Process_auth_registration_login_participant" name="Account Registration &amp; Login" processRef="Process_auth_registration_login" />
  </bpmn:collaboration>
  <bpmn:process id="Process_auth_registration_login" name="Account Registration &amp; Login" isExecutable="false">
    <bpmn:laneSet id="Process_auth_registration_login_laneSet">
      <bpmn:lane id="Process_auth_registration_login_lane_0" name="New User">
        <bpmn:flowNodeRef>Process_auth_registration_login_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_g0</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_r1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_e1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_auth_registration_login_lane_1" name="Web App (SPA)">
        <bpmn:flowNodeRef>Process_auth_registration_login_r2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_g3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_auth_registration_login_lane_2" name="Returning User">
        <bpmn:flowNodeRef>Process_auth_registration_login_l1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_e2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_auth_registration_login_lane_3" name="Identity &amp; Access Service">
        <bpmn:flowNodeRef>Process_auth_registration_login_r4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_l2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_g2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_auth_registration_login_iss</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_auth_registration_login_start" name="Open CivicPulse" />
      <bpmn:exclusiveGateway id="Process_auth_registration_login_g0" name="Have an account?" />
      <bpmn:task id="Process_auth_registration_login_r1" name="Go to /register fill Name, Email, CPF, Password" />
      <bpmn:task id="Process_auth_registration_login_r2" name="Client-side validation (required fields + CPF 11 digits)" />
      <bpmn:exclusiveGateway id="Process_auth_registration_login_g1" name="Valid?" />
      <bpmn:task id="Process_auth_registration_login_e1" name="Show inline error" />
      <bpmn:task id="Process_auth_registration_login_r4" name="Create account (role=citizen) hash password, store CPF" />
      <bpmn:task id="Process_auth_registration_login_l1" name="Go to /login fill Email, Password" />
      <bpmn:task id="Process_auth_registration_login_l2" name="Verify credentials" />
      <bpmn:exclusiveGateway id="Process_auth_registration_login_g2" name="Match?" />
      <bpmn:task id="Process_auth_registration_login_e2" name="Show &quot;invalid credentials&quot;" />
      <bpmn:task id="Process_auth_registration_login_iss" name="Issue session/JWT + default permission set for role" />
      <bpmn:task id="Process_auth_registration_login_g3" name="Apply permission-based route guards, render nav" />
      <bpmn:endEvent id="Process_auth_registration_login_end" name="Redirect to /feed" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_0" sourceRef="Process_auth_registration_login_start" targetRef="Process_auth_registration_login_g0" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_1" sourceRef="Process_auth_registration_login_g0" targetRef="Process_auth_registration_login_r1" name="No" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_2" sourceRef="Process_auth_registration_login_g0" targetRef="Process_auth_registration_login_l1" name="Yes" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_3" sourceRef="Process_auth_registration_login_r1" targetRef="Process_auth_registration_login_r2" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_4" sourceRef="Process_auth_registration_login_r2" targetRef="Process_auth_registration_login_g1" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_5" sourceRef="Process_auth_registration_login_g1" targetRef="Process_auth_registration_login_e1" name="Invalid" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_6" sourceRef="Process_auth_registration_login_e1" targetRef="Process_auth_registration_login_r1" name="retry" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_7" sourceRef="Process_auth_registration_login_g1" targetRef="Process_auth_registration_login_r4" name="Valid" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_8" sourceRef="Process_auth_registration_login_l1" targetRef="Process_auth_registration_login_l2" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_9" sourceRef="Process_auth_registration_login_l2" targetRef="Process_auth_registration_login_g2" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_10" sourceRef="Process_auth_registration_login_g2" targetRef="Process_auth_registration_login_e2" name="No" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_11" sourceRef="Process_auth_registration_login_e2" targetRef="Process_auth_registration_login_l1" name="retry" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_12" sourceRef="Process_auth_registration_login_g2" targetRef="Process_auth_registration_login_iss" name="Yes" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_13" sourceRef="Process_auth_registration_login_r4" targetRef="Process_auth_registration_login_iss" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_14" sourceRef="Process_auth_registration_login_iss" targetRef="Process_auth_registration_login_g3" />
      <bpmn:sequenceFlow id="Process_auth_registration_login_flow_15" sourceRef="Process_auth_registration_login_g3" targetRef="Process_auth_registration_login_end" />
  </bpmn:process>
