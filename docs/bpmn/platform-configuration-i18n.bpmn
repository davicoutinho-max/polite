      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_9" sourceRef="Process_platform_configuration_i18n_t5" targetRef="Process_platform_configuration_i18n_t8" />
      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_10" sourceRef="Process_platform_configuration_i18n_t8" targetRef="Process_platform_configuration_i18n_t9" />
      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_11" sourceRef="Process_platform_configuration_i18n_t9" targetRef="Process_platform_configuration_i18n_g1" />
      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_12" sourceRef="Process_platform_configuration_i18n_g1" targetRef="Process_platform_configuration_i18n_t10" name="No" />
      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_13" sourceRef="Process_platform_configuration_i18n_g1" targetRef="Process_platform_configuration_i18n_end" name="Yes" />
      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_14" sourceRef="Process_platform_configuration_i18n_t10" targetRef="Process_platform_configuration_i18n_end" />
  </bpmn:process>
