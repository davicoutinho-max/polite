                   id="Definitions_platform_configuration_i18n"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Platform Configuration &amp; Internationalization">
  <bpmn:collaboration id="Collaboration_platform_configuration_i18n">
    <bpmn:participant id="Process_platform_configuration_i18n_participant" name="Platform Configuration &amp; Internationalization" processRef="Process_platform_configuration_i18n" />
  </bpmn:collaboration>
  <bpmn:process id="Process_platform_configuration_i18n" name="Platform Configuration &amp; Internationalization" isExecutable="false">
    <bpmn:laneSet id="Process_platform_configuration_i18n_laneSet">
      <bpmn:lane id="Process_platform_configuration_i18n_lane_0" name="Platform Admin">
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_start2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_start3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_platform_configuration_i18n_lane_1" name="Platform Configuration Service">
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t7</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_platform_configuration_i18n_lane_2" name="End User Session">
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t8</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_platform_configuration_i18n_lane_3" name="Feature Modules (consumers)">
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t9</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_t10</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_platform_configuration_i18n_end</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_platform_configuration_i18n_start" name="Manage Countries &amp; States" />
      <bpmn:task id="Process_platform_configuration_i18n_t1" name="Add/remove country (cascades: removes its states)" />
      <bpmn:task id="Process_platform_configuration_i18n_t2" name="Add/remove state (linked to a country)" />
      <bpmn:startEvent id="Process_platform_configuration_i18n_start2" name="Manage Languages" />
      <bpmn:task id="Process_platform_configuration_i18n_t3" name="Add language → seed empty translation slot for every key" />
      <bpmn:task id="Process_platform_configuration_i18n_t4" name="Set default language" />
      <bpmn:task id="Process_platform_configuration_i18n_t5" name="Remove language → prune its values from every key" />
      <bpmn:startEvent id="Process_platform_configuration_i18n_start3" name="Manage Translation Tags" />
      <bpmn:task id="Process_platform_configuration_i18n_t6" name="Add a new translation key" />
      <bpmn:task id="Process_platform_configuration_i18n_t7" name="Edit per-language value for each key" />
      <bpmn:task id="Process_platform_configuration_i18n_t8" name="User selects display language (chrome dropdown)" />
      <bpmn:task id="Process_platform_configuration_i18n_t9" name="Resolve key → value[lang] at render time" />
      <bpmn:exclusiveGateway id="Process_platform_configuration_i18n_g1" name="Value present for language?" />
      <bpmn:task id="Process_platform_configuration_i18n_t10" name="Fall back to literal template string" />
      <bpmn:endEvent id="Process_platform_configuration_i18n_end" name="UI fully localized for the session" />
      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_0" sourceRef="Process_platform_configuration_i18n_start" targetRef="Process_platform_configuration_i18n_t1" />
      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_1" sourceRef="Process_platform_configuration_i18n_t1" targetRef="Process_platform_configuration_i18n_t2" />
      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_2" sourceRef="Process_platform_configuration_i18n_start2" targetRef="Process_platform_configuration_i18n_t3" />
      <bpmn:sequenceFlow id="Process_platform_configuration_i18n_flow_3" sourceRef="Process_platform_configuration_i18n_t3" targetRef="Process_platform_configuration_i18n_t4" />
