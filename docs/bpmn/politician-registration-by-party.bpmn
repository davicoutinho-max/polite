<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   id="Definitions_politician_registration_by_party"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Politician Registration by a Party">
  <bpmn:collaboration id="Collaboration_politician_registration_by_party">
    <bpmn:participant id="Process_politician_registration_by_party_participant" name="Politician Registration by a Party" processRef="Process_politician_registration_by_party" />
  </bpmn:collaboration>
  <bpmn:process id="Process_politician_registration_by_party" name="Politician Registration by a Party" isExecutable="false">
    <bpmn:laneSet id="Process_politician_registration_by_party_laneSet">
      <bpmn:lane id="Process_politician_registration_by_party_lane_0" name="Party Admin (user)">
        <bpmn:flowNodeRef>Process_politician_registration_by_party_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_politician_registration_by_party_t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_politician_registration_by_party_e1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_politician_registration_by_party_e2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_politician_registration_by_party_e3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_politician_registration_by_party_end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_politician_registration_by_party_lane_1" name="Party Admin Module">
        <bpmn:flowNodeRef>Process_politician_registration_by_party_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_politician_registration_by_party_g2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_politician_registration_by_party_g3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_politician_registration_by_party_lane_2" name="Directory Service">
        <bpmn:flowNodeRef>Process_politician_registration_by_party_t2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_politician_registration_by_party_t4</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_politician_registration_by_party_lane_3" name="Party Service">
        <bpmn:flowNodeRef>Process_politician_registration_by_party_t3</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_politician_registration_by_party_start" name="Open Party Admin → Politicians → Register new" />
      <bpmn:task id="Process_politician_registration_by_party_t1" name="Fill Name, Handle, CPF, CNPJ, Position, Level, State" />
      <bpmn:exclusiveGateway id="Process_politician_registration_by_party_g1" name="Name/Position/ State present?" />
      <bpmn:task id="Process_politician_registration_by_party_e1" name="Show required-fields error" />
      <bpmn:exclusiveGateway id="Process_politician_registration_by_party_g2" name="CPF valid (11 digits)?" />
      <bpmn:task id="Process_politician_registration_by_party_e2" name="Show &quot;invalid CPF&quot;" />
      <bpmn:exclusiveGateway id="Process_politician_registration_by_party_g3" name="CNPJ valid (14 digits)?" />
      <bpmn:task id="Process_politician_registration_by_party_e3" name="Show &quot;invalid CNPJ&quot;" />
      <bpmn:task id="Process_politician_registration_by_party_t2" name="Create PoliticianSummary (verified=false, followers=0)" />
      <bpmn:task id="Process_politician_registration_by_party_t3" name="Link politician as Representative of the party" />
      <bpmn:task id="Process_politician_registration_by_party_t4" name="Politician searchable in public /politicians directory" />
      <bpmn:endEvent id="Process_politician_registration_by_party_end" name="Politician provisioned &amp; linked" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_0" sourceRef="Process_politician_registration_by_party_start" targetRef="Process_politician_registration_by_party_t1" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_1" sourceRef="Process_politician_registration_by_party_t1" targetRef="Process_politician_registration_by_party_g1" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_2" sourceRef="Process_politician_registration_by_party_g1" targetRef="Process_politician_registration_by_party_e1" name="No" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_3" sourceRef="Process_politician_registration_by_party_e1" targetRef="Process_politician_registration_by_party_t1" name="retry" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_4" sourceRef="Process_politician_registration_by_party_g1" targetRef="Process_politician_registration_by_party_g2" name="Yes" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_5" sourceRef="Process_politician_registration_by_party_g2" targetRef="Process_politician_registration_by_party_e2" name="No" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_6" sourceRef="Process_politician_registration_by_party_e2" targetRef="Process_politician_registration_by_party_t1" name="retry" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_7" sourceRef="Process_politician_registration_by_party_g2" targetRef="Process_politician_registration_by_party_g3" name="Yes" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_8" sourceRef="Process_politician_registration_by_party_g3" targetRef="Process_politician_registration_by_party_e3" name="No" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_9" sourceRef="Process_politician_registration_by_party_e3" targetRef="Process_politician_registration_by_party_t1" name="retry" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_10" sourceRef="Process_politician_registration_by_party_g3" targetRef="Process_politician_registration_by_party_t2" name="Yes" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_11" sourceRef="Process_politician_registration_by_party_t2" targetRef="Process_politician_registration_by_party_t3" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_12" sourceRef="Process_politician_registration_by_party_t3" targetRef="Process_politician_registration_by_party_t4" />
      <bpmn:sequenceFlow id="Process_politician_registration_by_party_flow_13" sourceRef="Process_politician_registration_by_party_t4" targetRef="Process_politician_registration_by_party_end" />
  </bpmn:process>
