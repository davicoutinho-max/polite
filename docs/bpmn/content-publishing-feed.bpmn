<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   id="Definitions_content_publishing_feed"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Content Publishing &amp; Feed Interaction">
  <bpmn:collaboration id="Collaboration_content_publishing_feed">
    <bpmn:participant id="Process_content_publishing_feed_participant" name="Content Publishing &amp; Feed Interaction" processRef="Process_content_publishing_feed" />
  </bpmn:collaboration>
  <bpmn:process id="Process_content_publishing_feed" name="Content Publishing &amp; Feed Interaction" isExecutable="false">
    <bpmn:laneSet id="Process_content_publishing_feed_laneSet">
      <bpmn:lane id="Process_content_publishing_feed_lane_0" name="Author — Text">
        <bpmn:flowNodeRef>Process_content_publishing_feed_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_content_publishing_feed_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_content_publishing_feed_t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_content_publishing_feed_t4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_content_publishing_feed_e1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_content_publishing_feed_lane_1" name="Author — Agenda">
        <bpmn:flowNodeRef>Process_content_publishing_feed_t2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_content_publishing_feed_lane_2" name="Author — Live">
        <bpmn:flowNodeRef>Process_content_publishing_feed_t3</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_content_publishing_feed_lane_3" name="Feed Service">
        <bpmn:flowNodeRef>Process_content_publishing_feed_g2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_content_publishing_feed_t5</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_content_publishing_feed_t6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_content_publishing_feed_t10</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_content_publishing_feed_end</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_content_publishing_feed_lane_4" name="Follower (Reader)">
        <bpmn:flowNodeRef>Process_content_publishing_feed_t8</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_content_publishing_feed_t9</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_content_publishing_feed_lane_5" name="Notification Service">
        <bpmn:flowNodeRef>Process_content_publishing_feed_t7</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_content_publishing_feed_start" name="Open composer (requires publish-content)" />
      <bpmn:exclusiveGateway id="Process_content_publishing_feed_g1" name="Post kind?" />
      <bpmn:task id="Process_content_publishing_feed_t1" name="Text: write content" />
      <bpmn:task id="Process_content_publishing_feed_t2" name="Agenda: title, date, location" />
      <bpmn:task id="Process_content_publishing_feed_t3" name="Live: video/channel id, live-now or scheduled" />
      <bpmn:task id="Process_content_publishing_feed_t4" name="Choose visibility (public/private)" />
      <bpmn:exclusiveGateway id="Process_content_publishing_feed_g2" name="Required fields for kind present?" />
      <bpmn:task id="Process_content_publishing_feed_e1" name="Block publish" />
      <bpmn:task id="Process_content_publishing_feed_t5" name="Persist Post (id, tags, metrics=0)" />
      <bpmn:task id="Process_content_publishing_feed_t6" name="Prepend to feed store (invalidate feed cache)" />
      <bpmn:task id="Process_content_publishing_feed_t7" name="Fan-out notification to followers (async)" />
      <bpmn:task id="Process_content_publishing_feed_t8" name="Browse feed (Top / Latest / Following)" />
      <bpmn:task id="Process_content_publishing_feed_t9" name="Like / Comment" />
      <bpmn:task id="Process_content_publishing_feed_t10" name="Atomically update metrics (likes/comments)" />
      <bpmn:endEvent id="Process_content_publishing_feed_end" name="Post live &amp; interactive" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_0" sourceRef="Process_content_publishing_feed_start" targetRef="Process_content_publishing_feed_g1" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_1" sourceRef="Process_content_publishing_feed_g1" targetRef="Process_content_publishing_feed_t1" name="text" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_2" sourceRef="Process_content_publishing_feed_g1" targetRef="Process_content_publishing_feed_t2" name="agenda" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_3" sourceRef="Process_content_publishing_feed_g1" targetRef="Process_content_publishing_feed_t3" name="live" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_4" sourceRef="Process_content_publishing_feed_t1" targetRef="Process_content_publishing_feed_t4" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_5" sourceRef="Process_content_publishing_feed_t2" targetRef="Process_content_publishing_feed_t4" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_6" sourceRef="Process_content_publishing_feed_t3" targetRef="Process_content_publishing_feed_t4" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_7" sourceRef="Process_content_publishing_feed_t4" targetRef="Process_content_publishing_feed_g2" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_8" sourceRef="Process_content_publishing_feed_g2" targetRef="Process_content_publishing_feed_e1" name="No" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_9" sourceRef="Process_content_publishing_feed_e1" targetRef="Process_content_publishing_feed_t4" name="retry" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_10" sourceRef="Process_content_publishing_feed_g2" targetRef="Process_content_publishing_feed_t5" name="Yes" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_11" sourceRef="Process_content_publishing_feed_t5" targetRef="Process_content_publishing_feed_t6" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_12" sourceRef="Process_content_publishing_feed_t6" targetRef="Process_content_publishing_feed_t7" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_13" sourceRef="Process_content_publishing_feed_t6" targetRef="Process_content_publishing_feed_t8" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_14" sourceRef="Process_content_publishing_feed_t8" targetRef="Process_content_publishing_feed_t9" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_15" sourceRef="Process_content_publishing_feed_t9" targetRef="Process_content_publishing_feed_t10" />
      <bpmn:sequenceFlow id="Process_content_publishing_feed_flow_16" sourceRef="Process_content_publishing_feed_t10" targetRef="Process_content_publishing_feed_end" />
  </bpmn:process>
