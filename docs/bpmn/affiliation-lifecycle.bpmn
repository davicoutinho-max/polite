      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_lane_3_di" bpmnElement="Process_affiliation_lifecycle_lane_3" isHorizontal="true">
        <dc:Bounds x="40" y="490" width="2150" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_start_di" bpmnElement="Process_affiliation_lifecycle_start">
        <dc:Bounds x="315" y="95" width="40" height="40" />
        <bpmndi:BPMNLabel><dc:Bounds x="315" y="137" width="40" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_t1_di" bpmnElement="Process_affiliation_lifecycle_t1">
        <dc:Bounds x="435" y="230" width="140" height="70" />
        <bpmndi:BPMNLabel><dc:Bounds x="435" y="302" width="140" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_t2_di" bpmnElement="Process_affiliation_lifecycle_t2">
        <dc:Bounds x="605" y="380" width="140" height="70" />
        <bpmndi:BPMNLabel><dc:Bounds x="605" y="452" width="140" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_g1_di" bpmnElement="Process_affiliation_lifecycle_g1">
        <dc:Bounds x="822" y="392" width="46" height="46" />
        <bpmndi:BPMNLabel><dc:Bounds x="822" y="440" width="46" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_t3_di" bpmnElement="Process_affiliation_lifecycle_t3">
        <dc:Bounds x="911" y="380" width="140" height="70" />
        <bpmndi:BPMNLabel><dc:Bounds x="911" y="452" width="140" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_end1_di" bpmnElement="Process_affiliation_lifecycle_end1">
        <dc:Bounds x="1131" y="95" width="40" height="40" />
        <bpmndi:BPMNLabel><dc:Bounds x="1131" y="137" width="40" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_t4_di" bpmnElement="Process_affiliation_lifecycle_t4">
        <dc:Bounds x="1115" y="380" width="140" height="70" />
        <bpmndi:BPMNLabel><dc:Bounds x="1115" y="452" width="140" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_t5_di" bpmnElement="Process_affiliation_lifecycle_t5">
        <dc:Bounds x="1285" y="380" width="140" height="70" />
        <bpmndi:BPMNLabel><dc:Bounds x="1285" y="452" width="140" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_msg_di" bpmnElement="Process_affiliation_lifecycle_msg">
        <dc:Bounds x="1505" y="545" width="40" height="40" />
        <bpmndi:BPMNLabel><dc:Bounds x="1505" y="587" width="40" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_t6_di" bpmnElement="Process_affiliation_lifecycle_t6">
        <dc:Bounds x="1625" y="230" width="140" height="70" />
        <bpmndi:BPMNLabel><dc:Bounds x="1625" y="302" width="140" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_t7_di" bpmnElement="Process_affiliation_lifecycle_t7">
        <dc:Bounds x="1795" y="230" width="140" height="70" />
        <bpmndi:BPMNLabel><dc:Bounds x="1795" y="302" width="140" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_end2_di" bpmnElement="Process_affiliation_lifecycle_end2">
        <dc:Bounds x="2015" y="95" width="40" height="40" />
        <bpmndi:BPMNLabel><dc:Bounds x="2015" y="137" width="40" height="30" /></bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNEdge id="Process_affiliation_lifecycle_flow_0_di" bpmnElement="Process_affiliation_lifecycle_flow_0">
        <di:waypoint x="335" y="115" />
        <di:waypoint x="505" y="265" />
      </bpmndi:BPMNEdge>
      <bpmndi:BPMNEdge id="Process_affiliation_lifecycle_flow_1_di" bpmnElement="Process_affiliation_lifecycle_flow_1">
