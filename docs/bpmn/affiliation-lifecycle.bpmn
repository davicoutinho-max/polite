<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL"
                   xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI"
                   xmlns:dc="http://www.omg.org/spec/DD/20100524/DC"
                   xmlns:di="http://www.omg.org/spec/DD/20100524/DI"
                   id="Definitions_affiliation_lifecycle"
                   targetNamespace="https://civicpulse.example/bpmn"
                   name="Party Affiliation Request Lifecycle">
  <bpmn:collaboration id="Collaboration_affiliation_lifecycle">
    <bpmn:participant id="Process_affiliation_lifecycle_participant" name="Party Affiliation Request Lifecycle" processRef="Process_affiliation_lifecycle" />
  </bpmn:collaboration>
  <bpmn:process id="Process_affiliation_lifecycle" name="Party Affiliation Request Lifecycle" isExecutable="false">
    <bpmn:laneSet id="Process_affiliation_lifecycle_laneSet">
      <bpmn:lane id="Process_affiliation_lifecycle_lane_0" name="Citizen">
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_end1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_end2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_affiliation_lifecycle_lane_1" name="Membership/Wallet Service">
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_t1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_t6</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_t7</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_affiliation_lifecycle_lane_2" name="Party (local directory)">
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_t2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_g1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_t3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_t4</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_t5</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Process_affiliation_lifecycle_lane_3" name="Electoral Justice (external)">
        <bpmn:flowNodeRef>Process_affiliation_lifecycle_msg</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
      <bpmn:startEvent id="Process_affiliation_lifecycle_start" name="Request affiliation from Wallet page" />
      <bpmn:task id="Process_affiliation_lifecycle_t1" name="status = requested push notification" />
      <bpmn:task id="Process_affiliation_lifecycle_t2" name="Review documents &amp; contribution (manual)" />
      <bpmn:exclusiveGateway id="Process_affiliation_lifecycle_g1" name="Valid?" />
      <bpmn:task id="Process_affiliation_lifecycle_t3" name="Reject request" />
      <bpmn:endEvent id="Process_affiliation_lifecycle_end1" name="Rejected (notify citizen)" />
      <bpmn:task id="Process_affiliation_lifecycle_t4" name="status = party-approved" />
      <bpmn:task id="Process_affiliation_lifecycle_t5" name="File affiliation with Electoral Justice" />
      <bpmn:intermediateCatchEvent id="Process_affiliation_lifecycle_msg" name="Confirmation received (async)"><bpmn:messageEventDefinition /></bpmn:intermediateCatchEvent>
      <bpmn:task id="Process_affiliation_lifecycle_t6" name="status = electoral-justice → affiliated" />
      <bpmn:task id="Process_affiliation_lifecycle_t7" name="Issue digital membership card (QR) + start billing" />
      <bpmn:endEvent id="Process_affiliation_lifecycle_end2" name="Officially affiliated, card active" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_0" sourceRef="Process_affiliation_lifecycle_start" targetRef="Process_affiliation_lifecycle_t1" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_1" sourceRef="Process_affiliation_lifecycle_t1" targetRef="Process_affiliation_lifecycle_t2" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_2" sourceRef="Process_affiliation_lifecycle_t2" targetRef="Process_affiliation_lifecycle_g1" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_3" sourceRef="Process_affiliation_lifecycle_g1" targetRef="Process_affiliation_lifecycle_t3" name="No" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_4" sourceRef="Process_affiliation_lifecycle_t3" targetRef="Process_affiliation_lifecycle_end1" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_5" sourceRef="Process_affiliation_lifecycle_g1" targetRef="Process_affiliation_lifecycle_t4" name="Yes" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_6" sourceRef="Process_affiliation_lifecycle_t4" targetRef="Process_affiliation_lifecycle_t5" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_7" sourceRef="Process_affiliation_lifecycle_t5" targetRef="Process_affiliation_lifecycle_msg" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_8" sourceRef="Process_affiliation_lifecycle_msg" targetRef="Process_affiliation_lifecycle_t6" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_9" sourceRef="Process_affiliation_lifecycle_t6" targetRef="Process_affiliation_lifecycle_t7" />
      <bpmn:sequenceFlow id="Process_affiliation_lifecycle_flow_10" sourceRef="Process_affiliation_lifecycle_t7" targetRef="Process_affiliation_lifecycle_end2" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_affiliation_lifecycle">
    <bpmndi:BPMNPlane id="Plane_affiliation_lifecycle" bpmnElement="Collaboration_affiliation_lifecycle">
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_participant_di" bpmnElement="Process_affiliation_lifecycle_participant" isHorizontal="true">
        <dc:Bounds x="10" y="30" width="2180" height="620" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_lane_0_di" bpmnElement="Process_affiliation_lifecycle_lane_0" isHorizontal="true">
        <dc:Bounds x="40" y="40" width="2150" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_lane_1_di" bpmnElement="Process_affiliation_lifecycle_lane_1" isHorizontal="true">
        <dc:Bounds x="40" y="190" width="2150" height="150" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Process_affiliation_lifecycle_lane_2_di" bpmnElement="Process_affiliation_lifecycle_lane_2" isHorizontal="true">
