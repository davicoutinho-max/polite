# Copy this file to .env before running `docker compose up`.
# These are LOCAL DEVELOPMENT defaults only — never reuse these values
# outside a developer's machine. Production credentials are injected by
# Vault/KMS at deploy time (see docs/architecture/system-architecture.html).

# ---- Postgres superuser (used only by init scripts / pgAdmin) ----
POSTGRES_SUPERUSER=postgres
POSTGRES_SUPERUSER_PASSWORD=postgres_dev_only

# ---- Per-service database credentials ----
# Convention: database = <service>_service, role = <service>_service_app
IDENTITY_DB_PASSWORD=identity_dev_pw
DIRECTORY_DB_PASSWORD=directory_dev_pw
PARTY_MANAGEMENT_DB_PASSWORD=party_mgmt_dev_pw
PLATFORM_CONFIGURATION_DB_PASSWORD=platform_cfg_dev_pw
MEMBERSHIP_AFFILIATION_DB_PASSWORD=membership_dev_pw
PAYMENTS_DB_PASSWORD=payments_dev_pw
FEED_CONTENT_DB_PASSWORD=feed_dev_pw
LIVE_STREAMING_DB_PASSWORD=live_dev_pw
FUNDRAISING_DB_PASSWORD=fundraising_dev_pw
ELECTIONS_DB_PASSWORD=elections_dev_pw
PARTICIPATION_DB_PASSWORD=participation_dev_pw
MESSAGING_DB_PASSWORD=messaging_dev_pw
NOTIFICATION_DB_PASSWORD=notification_dev_pw
PRIVACY_COMPLIANCE_DB_PASSWORD=privacy_dev_pw
LEGISLATIVE_DB_PASSWORD=legislative_dev_pw
ACTIVITY_FEED_DB_PASSWORD=activity_feed_dev_pw
ANALYTICS_DB_PASSWORD=analytics_dev_pw
ASSISTANT_DB_PASSWORD=assistant_dev_pw

# ---- Shared infrastructure ----
REDIS_PASSWORD=redis_dev_pw
ELASTIC_PASSWORD=elastic_dev_pw
MINIO_ROOT_USER=civicpulse
MINIO_ROOT_PASSWORD=minio_dev_pw_change_me
PGADMIN_EMAIL=dev@civicpulse.dev
PGADMIN_PASSWORD=pgadmin_dev_pw
